      "source": [
        "import cv2\n",
        "image=cv2.imread('/content/drive/MyDrive/MLT/squirrel.jpg')\n",
        "gray_image=cv2.cvtColor(image,cv2.COLOR_BGR2GRAY)\n",
        "edges=cv2.Canny(gray_image,200,250)\n",
        "from google.colab.patches import cv2_imshow\n",
        "cv2_imshow(image)\n",
        "cv2_imshow(edges)"
